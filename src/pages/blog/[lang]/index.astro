---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { translations } from '../../../i18n/translations.ts';
import type { Lang } from '../../../i18n/translations.ts';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = translations[lang];

const allPosts = await getCollection('blog', ({ data }) => data.lang === lang);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const pageTitle = `${t.blog_title} — Benjamin Manguet`;
---

<Layout title={pageTitle} description={t.blog_latest}>
  <Nav />
  <main class="blog-list-page" data-lang={lang}>
    <div class="container">
      <nav class="breadcrumb">
        <a href="/" class="breadcrumb__link">{t.blog_back_home}</a>
      </nav>

      <div class="section-label">
        <span class="mono">{t.section_blog_label}</span>
      </div>
      <h1 class="section-title">{t.blog_title}</h1>

      {posts.length === 0 ? (
        <p class="blog-empty">{t.blog_no_posts}</p>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.data.slug}
              lang={lang}
            />
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .blog-list-page {
    padding: 80px 0 100px;
    min-height: 100vh;
  }

  .breadcrumb {
    margin-bottom: 32px;
  }

  .breadcrumb__link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    color: var(--purple-light);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .breadcrumb__link:hover {
    opacity: 0.75;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin-bottom: 60px;
    color: var(--white);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .blog-empty {
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
