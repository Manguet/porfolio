---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
---
<nav class="nav" id="nav">
  <div class="container">
    <!-- Logo image -->
    <a href="#hero" class="nav-logo" aria-label="Benjamin Manguet">
      <div class="nav-logo-wrap">
        <Image src={logo} alt="Logo Benjamin Manguet" class="nav-logo-img" width={34} height={34} loading="eager" />
      </div>
      <span class="nav-logo-text mono">Manguet<span>.</span></span>
    </a>

    <ul class="nav-links">
      <li><a href="#services" data-i18n="nav_services">Services</a></li>
      <li><a href="#projects" data-i18n="nav_projects">Réalisations</a></li>
      <li><a href="#stack" data-i18n="nav_stack">Stack</a></li>
      <li><a href="#experience" data-i18n="nav_experience">Expérience</a></li>
      <li>
        <!-- Switcher de langue -->
        <button class="lang-switch" id="lang-switch" aria-label="Changer de langue">
          <span class="lang-opt" data-lang-opt="fr">FR</span>
          <span class="lang-sep">/</span>
          <span class="lang-opt" data-lang-opt="en">EN</span>
        </button>
      </li>
      <li><a href="#contact" class="nav-cta" data-i18n="nav_contact">Me contacter</a></li>
    </ul>

    <div class="nav-right-mobile">
      <button class="lang-switch lang-switch--mobile" id="lang-switch-mobile" aria-label="Changer de langue">
        <span class="lang-opt" data-lang-opt="fr">FR</span>
        <span class="lang-sep">/</span>
        <span class="lang-opt" data-lang-opt="en">EN</span>
      </button>
      <button class="nav-burger" id="burger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<div class="mobile-menu" id="mobile-menu">
  <a href="#services" class="mobile-link" data-i18n="nav_services">Services</a>
  <a href="#stack" class="mobile-link" data-i18n="nav_stack">Stack</a>
  <a href="#experience" class="mobile-link" data-i18n="nav_experience">Expérience</a>
  <a href="#contact" class="mobile-link mobile-link--cta" data-i18n="nav_contact">Me contacter</a>
</div>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 16px 0;
    transition: background 0.3s, padding 0.3s, border-bottom 0.3s;
  }

  .nav.scrolled {
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(12px);
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }

  .nav .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Logo */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-logo-wrap {
    width: 34px; height: 34px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .nav-logo-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  .nav-logo-text {
    font-size: 18px;
    font-weight: 700;
    color: var(--white);
    letter-spacing: 0.04em;
  }

  .nav-logo-text span { color: var(--purple); }

  /* Liens */
  .nav-links {
    display: flex;
    list-style: none;
    gap: 28px;
    align-items: center;
  }

  .nav-links a {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--white); }

  .nav-cta {
    background: var(--purple) !important;
    color: var(--white) !important;
    padding: 9px 20px;
    border-radius: 4px;
    font-weight: 600 !important;
  }

  .nav-cta:hover {
    background: var(--purple-light) !important;
  }

  /* Switcher de langue */
  .lang-switch {
    display: flex;
    align-items: center;
    gap: 4px;
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 5px 10px;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .lang-switch:hover { border-color: rgba(124,58,237,0.4); }

  .lang-opt {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    transition: color 0.2s;
    cursor: pointer;
  }

  .lang-opt.active { color: var(--purple-light); }

  .lang-sep {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--border);
  }

  /* Burger + switcher mobile */
  .nav-right-mobile {
    display: none;
    align-items: center;
    gap: 12px;
  }

  .nav-burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--white);
    transition: all 0.3s;
  }

  /* Menu mobile */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: var(--bg);
    z-index: 99;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 32px;
  }

  .mobile-menu.open { display: flex; }

  .mobile-link {
    font-size: 28px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text);
    transition: color 0.2s;
  }

  .mobile-link:hover { color: var(--purple-light); }

  .mobile-link--cta {
    color: var(--purple-light);
    border: 2px solid var(--purple);
    padding: 14px 40px;
    border-radius: 4px;
    font-size: 20px;
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-right-mobile { display: flex; }
  }
</style>

<script>
  import { translations, type Lang } from '../i18n/translations';

  // ── État de la langue ──────────────────────────────────────────────
  const STORAGE_KEY = 'bm-lang';
  let currentLang: Lang = (localStorage.getItem(STORAGE_KEY) as Lang) || 'fr';

  // ── Mise à jour DOM ────────────────────────────────────────────────
  function applyLang(lang: Lang) {
    currentLang = lang;
    localStorage.setItem(STORAGE_KEY, lang);

    const t = translations[lang];
    document.documentElement.setAttribute('lang', lang);
    document.documentElement.setAttribute('data-lang', lang);

    // Textes simples
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n') as keyof typeof t;
      if (key && t[key]) el.textContent = t[key] as string;
    });

    // Textes avec HTML (innerHTML)
    document.querySelectorAll<HTMLElement>('[data-i18n-html]').forEach(el => {
      const key = el.getAttribute('data-i18n-html') as keyof typeof t;
      if (key && t[key]) el.innerHTML = t[key] as string;
    });

    // Placeholders
    document.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[data-i18n-ph]').forEach(el => {
      const key = el.getAttribute('data-i18n-ph') as keyof typeof t;
      if (key && t[key]) el.placeholder = t[key] as string;
    });

    // Options select
    document.querySelectorAll<HTMLOptionElement>('[data-i18n-opt]').forEach(el => {
      const key = el.getAttribute('data-i18n-opt') as keyof typeof t;
      if (key && t[key]) el.textContent = t[key] as string;
    });

    // Mise à jour visuelle des switchers
    document.querySelectorAll('.lang-opt').forEach(opt => {
      const l = opt.getAttribute('data-lang-opt');
      opt.classList.toggle('active', l === lang);
    });
  }

  // ── Écouteurs ──────────────────────────────────────────────────────
  function bindSwitcher(id: string) {
    const btn = document.getElementById(id);
    if (!btn) return;
    btn.addEventListener('click', (e) => {
      const opt = (e.target as HTMLElement).closest('[data-lang-opt]');
      if (opt) {
        const l = opt.getAttribute('data-lang-opt') as Lang;
        if (l && l !== currentLang) applyLang(l);
      } else {
        applyLang(currentLang === 'fr' ? 'en' : 'fr');
      }
    });
  }

  bindSwitcher('lang-switch');
  bindSwitcher('lang-switch-mobile');

  // ── Scroll nav ─────────────────────────────────────────────────────
  const nav = document.getElementById('nav')!;
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 40);
  });

  // ── Burger ─────────────────────────────────────────────────────────
  const burger = document.getElementById('burger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  burger.addEventListener('click', () => mobileMenu.classList.toggle('open'));
  mobileMenu.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => mobileMenu.classList.remove('open'));
  });

  // ── Init ───────────────────────────────────────────────────────────
  applyLang(currentLang);
</script>
