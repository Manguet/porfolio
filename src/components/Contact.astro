---
---
<section class="section" id="contact" style="background: var(--bg-2); border-top: 1px solid var(--border);">
  <div class="container">
    <div class="section-label" data-i18n="section_contact_label">Contact</div>
    <h2 class="section-title">
      <span data-i18n="section_contact_title">Travaillons ensemble</span>
    </h2>

    <!-- Bandeau devis -->
    <div class="devis-banner">
      <div class="devis-items">
        <div class="devis-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          <span data-i18n="devis_item1">Devis sous 48h</span>
        </div>
        <div class="devis-sep" aria-hidden="true">·</div>
        <div class="devis-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.1 6.1l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <span data-i18n="devis_item2">Premier échange gratuit</span>
        </div>
        <div class="devis-sep" aria-hidden="true">·</div>
        <div class="devis-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
          <span data-i18n="devis_item3">Tarif sur devis selon mission</span>
        </div>
      </div>
    </div>

    <div class="contact-layout">
      <!-- Infos -->
      <div class="contact-info">
        <p class="contact-intro" data-i18n-html="contact_intro">
          Disponible pour des missions de <strong>développement</strong>,
          d'<strong>architecture</strong> ou d'<strong>encadrement technique</strong>.
          Basé en Charente-Maritime, remote ou sur site.
        </p>

        <div class="contact-items">
          <a href="mailto:benjamin.manguet@gmail.com" class="contact-item">
            <div class="ci-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <p class="ci-label mono" data-i18n="contact_email_label">Email</p>
              <p class="ci-value">benjamin.manguet@gmail.com</p>
            </div>
          </a>

          <a href="tel:+33637505098" class="contact-item">
            <div class="ci-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.1 6.1l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <p class="ci-label mono" data-i18n="contact_phone_label">Téléphone</p>
              <p class="ci-value">06 37 50 50 98</p>
            </div>
          </a>

          <div class="contact-item no-link">
            <div class="ci-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="ci-label mono" data-i18n="contact_loc_label">Localisation</p>
              <p class="ci-value" data-i18n="contact_loc_val">Angliers · 17 · Charente-Maritime</p>
            </div>
          </div>
        </div>

        <a href="https://calendly.com/benjamin-manguet" target="_blank" rel="noopener" class="calendly-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
            <path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/>
          </svg>
          <div>
            <p class="calendly-label mono" data-i18n="calendly_label">Réserver un appel</p>
            <p class="calendly-sub" data-i18n="calendly_sub">30 min ou 60 min · Premier échange gratuit</p>
          </div>
          <svg class="calendly-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>

        <div class="social-links">
          <a href="https://www.linkedin.com/in/benjaminmanguet" target="_blank" rel="noopener" class="social-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
            </svg>
            LinkedIn
          </a>
          <a href="https://github.com/Manguet" target="_blank" rel="noopener" class="social-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
            </svg>
            GitHub
          </a>
          <a href="https://www.malt.fr/profile/benjaminmanguet" target="_blank" rel="noopener" class="social-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
            Malt
          </a>
        </div>
      </div>

      <!-- Formulaire -->
      <form class="contact-form" id="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" novalidate>
        <input type="hidden" name="form-name" value="contact" />
        <input type="hidden" name="bot-field" />

        <div class="form-group">
          <label class="form-label mono" for="name" data-i18n="form_name_label">Nom</label>
          <input type="text" id="name" name="name" class="form-input" data-i18n-ph="form_name_ph" placeholder="Votre nom" required />
        </div>
        <div class="form-group">
          <label class="form-label mono" for="email" data-i18n="form_email_label">Email</label>
          <input type="email" id="email" name="email" class="form-input" data-i18n-ph="form_email_ph" placeholder="votre@email.fr" required />
        </div>
        <div class="form-group">
          <label class="form-label mono" for="subject" data-i18n="form_subj_label">Objet</label>
          <select id="subject" name="subject" class="form-input">
            <option value="" data-i18n-opt="form_subj_ph">Sélectionner...</option>
            <option value="dev" data-i18n-opt="form_subj_o1">Mission développement</option>
            <option value="audit" data-i18n-opt="form_subj_o2">Audit sécurité</option>
            <option value="lead" data-i18n-opt="form_subj_o3">Lead / Architecture</option>
            <option value="formation" data-i18n-opt="form_subj_o4">Formation IA ou équipe</option>
            <option value="marque-blanche" data-i18n-opt="form_subj_o5">Sous-traitance / Marque blanche</option>
            <option value="autre" data-i18n-opt="form_subj_o6">Autre</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label mono" for="message" data-i18n="form_msg_label">Message</label>
          <textarea id="message" name="message" class="form-input form-textarea" data-i18n-ph="form_msg_ph" placeholder="Décrivez votre projet ou votre besoin..." required rows="5"></textarea>
        </div>

        <button type="submit" class="form-submit" id="form-submit-btn">
          <span class="btn-label" data-i18n="form_submit">Envoyer le message</span>
          <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
          <svg class="btn-spinner" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
            <path d="M21 12a9 9 0 1 1-6.22-8.56"/>
          </svg>
        </button>

        <div id="form-success" class="form-feedback form-feedback--success" style="display:none" role="alert">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span data-i18n="form_success">Message envoyé ! Je vous réponds sous 24h.</span>
        </div>
        <div id="form-error" class="form-feedback form-feedback--error" style="display:none" role="alert">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span data-i18n="form_error">Une erreur est survenue. Écrivez-moi directement à</span>
          <a href="mailto:benjamin.manguet@gmail.com">benjamin.manguet@gmail.com</a>
        </div>

        <p class="form-note mono">
          <span data-i18n="form_note">* Vous pouvez aussi écrire directement à</span>
          <a href="mailto:benjamin.manguet@gmail.com">benjamin.manguet@gmail.com</a>
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .devis-banner {
    background: linear-gradient(135deg, rgba(124,58,237,.08), rgba(76,29,149,.04));
    border: 1px solid rgba(124,58,237,.25);
    border-radius: 8px;
    padding: 16px 24px;
    margin-bottom: 48px;
  }

  .devis-items {
    display: flex; align-items: center;
    flex-wrap: wrap; gap: 12px 20px;
    justify-content: center;
  }

  .devis-item {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 600;
    color: var(--text);
  }

  .devis-item svg { color: var(--purple-light); flex-shrink: 0; }

  .devis-sep {
    color: var(--border);
    font-size: 18px; line-height: 1;
  }

  @media (max-width: 600px) { .devis-sep { display: none; } }

  .contact-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }

  .contact-intro { font-size: 1rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 36px; }
  .contact-intro strong { color: var(--text); }

  .contact-items { display: flex; flex-direction: column; gap: 20px; margin-bottom: 36px; }

  .contact-item {
    display: flex; gap: 16px; align-items: flex-start;
    padding: 16px 20px;
    background: var(--bg-3); border: 1px solid var(--border);
    border-radius: 6px; transition: border-color .2s, transform .2s; cursor: pointer;
  }

  .contact-item:not(.no-link):hover { border-color: rgba(124,58,237,.4); transform: translateX(4px); }

  .ci-icon { flex-shrink: 0; color: var(--purple-light); margin-top: 2px; }

  .ci-label { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 2px; }
  .ci-value { font-size: 14px; color: var(--text); font-weight: 500; }

  .calendly-btn {
    display: flex; align-items: center; gap: 14px;
    padding: 16px 20px;
    background: linear-gradient(135deg, rgba(124,58,237,.1), rgba(76,29,149,.05));
    border: 1px solid rgba(124,58,237,.35);
    border-radius: 6px;
    margin-bottom: 20px;
    transition: border-color .2s, transform .2s, box-shadow .2s;
    color: inherit;
  }
  .calendly-btn:hover { border-color: var(--purple-light); transform: translateX(4px); box-shadow: 0 4px 20px rgba(124,58,237,.15); }
  .calendly-btn > svg:first-child { flex-shrink: 0; color: var(--purple-light); }
  .calendly-btn > div { flex: 1; }
  .calendly-label { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--purple-light); margin-bottom: 2px; }
  .calendly-sub { font-size: 13px; color: var(--text); font-weight: 500; }
  .calendly-arrow { flex-shrink: 0; color: var(--purple-light); }

  .social-links { display: flex; gap: 12px; flex-wrap: wrap; }

  .social-btn {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 600;
    color: var(--text-muted);
    background: var(--bg-3); border: 1px solid var(--border);
    padding: 10px 16px; border-radius: 4px;
    transition: color .2s, border-color .2s, transform .2s;
  }

  .social-btn:hover { color: var(--purple-light); border-color: rgba(124,58,237,.4); transform: translateY(-2px); }

  .contact-form {
    display: flex; flex-direction: column; gap: 20px;
    background: var(--bg-3); border: 1px solid var(--border);
    border-radius: 8px; padding: 32px 28px;
  }

  .form-group { display: flex; flex-direction: column; gap: 8px; }

  .form-label { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); }

  .form-input {
    background: var(--bg-2); border: 1px solid var(--border); border-radius: 4px;
    color: var(--text); font-family: 'Space Grotesk', sans-serif; font-size: 14px;
    padding: 12px 16px; transition: border-color .2s, box-shadow .2s;
    outline: none; width: 100%; appearance: none;
  }

  .form-input:focus { border-color: var(--purple); box-shadow: 0 0 0 3px rgba(124,58,237,.15); }
  .form-input::placeholder { color: var(--text-muted); opacity: .6; }
  .form-textarea { resize: vertical; min-height: 120px; }
  select.form-input { color: var(--text); cursor: pointer; }
  select.form-input option { background: var(--bg-2); }

  .form-submit {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    background: var(--purple); color: var(--white);
    border: none; border-radius: 4px;
    font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    padding: 16px; cursor: pointer;
    transition: background .2s, transform .2s, box-shadow .2s;
  }

  .form-submit:hover { background: var(--purple-light); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(124,58,237,.3); }

  .form-note { font-size: 11px; color: var(--text-muted); line-height: 1.6; letter-spacing: .03em; }
  .form-note a { color: var(--purple-light); text-decoration: underline; }

  .form-submit:disabled { opacity: .6; cursor: not-allowed; transform: none; }

  .btn-spinner { animation: spin 0.8s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .form-feedback {
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; font-weight: 500;
    padding: 12px 16px; border-radius: 4px;
  }
  .form-feedback--success { color: #34d399; background: rgba(52,211,153,.1); border: 1px solid rgba(52,211,153,.3); }
  .form-feedback--error   { color: #f87171; background: rgba(248,113,113,.1); border: 1px solid rgba(248,113,113,.3); flex-wrap: wrap; }
  .form-feedback--error a { color: #f87171; text-decoration: underline; }

  @media (max-width: 900px) { .contact-layout { grid-template-columns: 1fr; } }
</style>

<script>
  const form      = document.getElementById('contact-form')    as HTMLFormElement;
  const btn       = document.getElementById('form-submit-btn') as HTMLButtonElement;
  const btnLabel  = btn.querySelector('.btn-label')            as HTMLElement;
  const btnIcon   = btn.querySelector('.btn-icon')             as HTMLElement;
  const btnSpinner= btn.querySelector('.btn-spinner')          as HTMLElement;
  const success   = document.getElementById('form-success')    as HTMLElement;
  const error     = document.getElementById('form-error')      as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Validation basique
    const name    = (document.getElementById('name')    as HTMLInputElement).value.trim();
    const email   = (document.getElementById('email')   as HTMLInputElement).value.trim();
    const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();
    if (!name || !email || !message) return;

    // État chargement
    btn.disabled   = true;
    btnIcon.style.display    = 'none';
    btnSpinner.style.display = 'block';
    success.style.display = 'none';
    error.style.display   = 'none';

    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form) as any).toString(),
      });

      if (res.ok) {
        success.style.display = 'flex';
        form.reset();
      } else {
        error.style.display = 'flex';
      }
    } catch {
      error.style.display = 'flex';
    } finally {
      btn.disabled = false;
      btnIcon.style.display    = 'block';
      btnSpinner.style.display = 'none';
    }
  });
</script>
