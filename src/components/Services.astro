---
---
<section class="section" id="services">
  <div class="container">
    <div class="section-label" data-i18n="section_services_label">Services</div>
    <h2 class="section-title">
      <span data-i18n="section_services_title">Ce que je propose</span>
    </h2>

    <div class="services-grid">

      <!-- Card 1 — Dev -->
      <article class="service-card" style="--i:0">
        <div class="card-top">
          <div class="card-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <span class="card-label mono" data-i18n="svc1_label">Développement</span>
        </div>
        <h3 class="card-title" data-i18n="svc1_title">Full-Stack PHP / Symfony</h3>
        <p class="card-desc" data-i18n="svc1_desc">Conception et développement d'applications web robustes. API REST, architecture hexagonale, React/Preact, Go et Python. Idéal pour PME et agences en sous-traitance.</p>
        <ul class="card-items">
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc1_i1">PHP 8 / Symfony 6-7</span></li>
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc1_i2">API REST &amp; React / Preact</span></li>
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc1_i3">Go, Python, Angular</span></li>
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc1_i4">Refactoring &amp; reprise legacy</span></li>
        </ul>
        <div class="card-line" aria-hidden="true"></div>
      </article>

      <!-- Card 2 — Audit Sécu (mise en avant) -->
      <article class="service-card service-card--featured" style="--i:1">
        <div class="card-top">
          <div class="card-icon card-icon--secu">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <span class="card-label mono" data-i18n="svc2_label">Sécurité</span>
        </div>
        <h3 class="card-title" data-i18n="svc2_title">Audit Sécurité Web</h3>
        <p class="card-desc" data-i18n="svc2_desc">Audit passif OWASP, headers HTTP, TLS, exposition de données, conformité RGPD technique. Rapport PDF priorisé livré sous 48h. Audit flash offert pour premier contact.</p>
        <ul class="card-items">
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc2_i1">OWASP Top 10</span></li>
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc2_i2">Headers HTTP &amp; TLS / SSL</span></li>
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc2_i3">Conformité RGPD technique</span></li>
          <li class="card-item mono card-item--highlight"><span class="ia">›</span><span data-i18n="svc2_i4">Audit flash gratuit (3 pages)</span></li>
        </ul>
        <div class="card-line" aria-hidden="true"></div>
      </article>

      <!-- Card 3 — DevOps -->
      <article class="service-card" style="--i:2">
        <div class="card-top">
          <div class="card-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>
              <path d="M15.54 8.46a5 5 0 0 1 0 7.07M8.46 8.46a5 5 0 0 0 0 7.07"/>
            </svg>
          </div>
          <span class="card-label mono" data-i18n="svc3_label">Architecture</span>
        </div>
        <h3 class="card-title" data-i18n="svc3_title">DevOps &amp; CI/CD</h3>
        <p class="card-desc" data-i18n="svc3_desc">Mise en place de pipelines CI/CD, architecture de solutions scalables, infrastructure et bonnes pratiques de déploiement.</p>
        <ul class="card-items">
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc3_i1">CI/CD (GitHub Actions, GitLab)</span></li>
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc3_i2">Docker &amp; orchestration</span></li>
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc3_i3">Architecture hexagonale</span></li>
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc3_i4">Code review &amp; PR</span></li>
        </ul>
        <div class="card-line" aria-hidden="true"></div>
      </article>

      <!-- Card 4 — Formation & IA -->
      <article class="service-card" style="--i:3">
        <div class="card-top">
          <div class="card-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <span class="card-label mono" data-i18n="svc4_label">Formation</span>
        </div>
        <h3 class="card-title" data-i18n="svc4_title">Formation &amp; IA</h3>
        <p class="card-desc" data-i18n="svc4_desc">Montée en compétences des équipes dev et non-tech sur les outils IA, les pratiques Agile/Scrum, et le lead technique. Accompagnement terrain.</p>
        <ul class="card-items">
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc4_i1">Formations outils IA</span></li>
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc4_i2">Lead technique &amp; mentoring</span></li>
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc4_i3">Scrum / Agile</span></li>
          <li class="card-item mono"><span class="ia">›</span><span data-i18n="svc4_i4">Analyses &amp; spécifications</span></li>
        </ul>
        <div class="card-line" aria-hidden="true"></div>
      </article>

    </div>

    <!-- Modes d'intervention -->
    <div class="modes-grid">
      <div class="mode-card">
        <div class="mode-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
          </svg>
        </div>
        <p class="mode-title mono" data-i18n="mode1_title">Marque blanche</p>
        <p class="mode-desc" data-i18n="mode1_desc">J'interviens pour vous, sous votre identité. Votre client final ne sait pas qu'un prestataire externe est impliqué. Idéal pour les agences qui souhaitent élargir leur offre.</p>
      </div>
      <div class="mode-card">
        <div class="mode-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <p class="mode-title mono" data-i18n="mode2_title">Régie</p>
        <p class="mode-desc" data-i18n="mode2_desc">Je rejoins votre équipe pour une durée déterminée, facturé à la journée ou au temps passé. Vous bénéficiez d'une ressource technique senior sans embauche permanente.</p>
      </div>
      <div class="mode-card">
        <div class="mode-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </div>
        <p class="mode-title mono" data-i18n="mode3_title">Remote</p>
        <p class="mode-desc" data-i18n="mode3_desc">Toutes mes missions sont disponibles à distance, sans contrainte géographique. Outils collaboratifs, réunions visio, livraisons via Git. Je suis aussi disponible sur site en Charente-Maritime et environs.</p>
      </div>
    </div>

    <!-- Différenciateur -->
    <div class="differentiator">
      <div class="diff-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
        </svg>
      </div>
      <div class="diff-content">
        <p class="diff-label mono" data-i18n="diff_label">Profil unique</p>
        <p class="diff-text" data-i18n-html="diff_text">
          Diplômé en <strong>Biologie</strong>, fort de <strong>8 ans en milieu médico-chirurgical</strong> et positionné sur deux axes complémentaires : <strong>développement</strong> et <strong>audit sécurité</strong>. J'interviens en direct, en marque blanche ou en régie pour des PME et des agences.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }

  .service-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 32px 28px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
    animation: fadeUp 0.6s ease both;
    animation-delay: calc(var(--i) * 0.08s);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--purple), var(--purple-light));
    transform: scaleX(0);
    transition: transform 0.3s;
  }

  .service-card:hover { border-color: rgba(124,58,237,.4); transform: translateY(-4px); }
  .service-card:hover::before { transform: scaleX(1); }

  /* Card mise en avant — Audit Sécu */
  .service-card--featured {
    border-color: rgba(124,58,237,.35);
    background: linear-gradient(145deg, rgba(124,58,237,.07) 0%, var(--bg-2) 60%);
  }

  .service-card--featured::before { transform: scaleX(1); }

.card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }

  .card-icon { color: var(--purple-light); display: flex; }
  .card-icon--secu { color: #a78bfa; filter: drop-shadow(0 0 6px rgba(167,139,250,.5)); }

  .card-label {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 3px 8px; border-radius: 3px;
  }

  .card-title {
    font-size: 1.2rem; font-weight: 700;
    color: var(--white); margin-bottom: 12px;
    text-transform: uppercase; letter-spacing: -0.01em;
  }

  .card-desc {
    font-size: .88rem; color: var(--text-muted);
    line-height: 1.7; margin-bottom: 20px;
  }

  .card-items { list-style: none; display: flex; flex-direction: column; gap: 7px; }

  .card-item {
    font-size: 12px; color: var(--text);
    display: flex; align-items: center; gap: 8px;
  }

  .ia { color: var(--purple-light); font-size: 15px; line-height: 1; flex-shrink: 0; }

  .card-item--highlight span:last-child {
    color: var(--purple-light);
    font-weight: 600;
  }

  .card-line {
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 50px;
    background: linear-gradient(to top, rgba(124,58,237,.04), transparent);
    pointer-events: none;
  }

  /* Modes d'intervention */
  .modes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }

  .mode-card {
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px 18px;
  }

  .mode-icon {
    color: var(--purple-light);
    margin-bottom: 10px;
    display: flex;
  }

  .mode-title {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--purple-light);
    margin-bottom: 8px;
  }

  .mode-desc {
    font-size: .82rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  @media (max-width: 700px) { .modes-grid { grid-template-columns: 1fr; } }

  /* Différenciateur */
  .differentiator {
    display: flex; gap: 24px; align-items: flex-start;
    background: linear-gradient(135deg, rgba(124,58,237,.1), rgba(76,29,149,.05));
    border: 1px solid rgba(124,58,237,.3);
    border-radius: 8px; padding: 28px 32px;
  }

  .diff-icon {
    flex-shrink: 0; color: var(--purple-light);
    background: rgba(124,58,237,.15);
    padding: 12px; border-radius: 6px; display: flex;
  }

  .diff-label {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--purple-light); margin-bottom: 8px;
  }

  .diff-text { font-size: .95rem; color: var(--text-muted); line-height: 1.7; }
  .diff-text strong { color: var(--text); }

  @media (max-width: 900px) { .services-grid { grid-template-columns: 1fr; } }
  @media (max-width: 600px) { .differentiator { flex-direction: column; gap: 16px; } }
</style>
