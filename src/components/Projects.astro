---
---
<section class="section" id="projects">
  <div class="container">
    <div class="section-label" data-i18n="section_projects_label">Réalisations</div>
    <h2 class="section-title">
      <span data-i18n="section_projects_title">Quelques projets</span>
    </h2>

    <div class="projects-grid">

      <!-- Error Explorer -->
      <article class="project-card project-card--featured" style="--i:0">
        <div class="pc-header">
          <div class="pc-meta">
            <span class="pc-badge mono pc-badge--wip" data-i18n="proj_wip">En cours</span>
          </div>
          <div class="pc-links">
            <!-- pas encore de lien public -->
          </div>
        </div>
        <h3 class="pc-title">Error Explorer</h3>
        <p class="pc-desc" data-i18n="proj1_desc">Solution SaaS de monitoring et de correction de bugs en temps réel. Détection automatique des erreurs, alertes et suggestions de correctifs intégrées directement dans le workflow de développement.</p>
        <div class="pc-tags">
          <span class="pc-tag mono">SaaS</span>
          <span class="pc-tag mono">PHP 8.2 / Symfony 6.4</span>
          <span class="pc-tag mono">Stimulus / Turbo</span>
          <span class="pc-tag mono">GitHub API</span>
          <span class="pc-tag mono">MySQL</span>
        </div>
      </article>

      <!-- Auditor -->
      <article class="project-card" style="--i:1">
        <div class="pc-header">
          <div class="pc-meta">
            <span class="pc-badge mono pc-badge--wip" data-i18n="proj_wip">En cours</span>
          </div>
          <div class="pc-links"></div>
        </div>
        <h3 class="pc-title">Auditor</h3>
        <p class="pc-desc" data-i18n="proj2_desc">Application de suivi et de gestion des audits de sécurité web. Centralise les résultats, priorise les vulnérabilités et génère des rapports structurés pour les équipes techniques et les décideurs.</p>
        <div class="pc-tags">
          <span class="pc-tag mono">Python 3.11+</span>
          <span class="pc-tag mono">FastAPI</span>
          <span class="pc-tag mono">PostgreSQL / Redis</span>
          <span class="pc-tag mono">OWASP</span>
        </div>
      </article>

      <!-- Hydro Explorer -->
      <article class="project-card project-card--featured" style="--i:2">
        <div class="pc-header">
          <div class="pc-meta">
            <span class="pc-badge mono pc-badge--live" data-i18n="proj_live">En ligne</span>
          </div>
          <div class="pc-links">
            <a href="https://manguet.github.io/hydro-explorer/" target="_blank" rel="noopener" class="pc-link" aria-label="Voir la démo">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              <span data-i18n="proj_visit">Visiter</span>
            </a>
            <a href="https://github.com/Manguet/hydro-explorer" target="_blank" rel="noopener" class="pc-link" aria-label="Voir sur GitHub">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
              GitHub
            </a>
          </div>
        </div>
        <h3 class="pc-title">Hydro Explorer</h3>
        <p class="pc-desc" data-i18n="proj_hydro_desc">Démo de visualisation hydrologique interactive construite sur l'API Hub'eau et Leaflet. Affichage en temps réel des stations de mesure, courbes de débit et niveaux d'eau sur le territoire du Marais poitevin.</p>
        <div class="pc-tags">
          <span class="pc-tag mono">Leaflet</span>
          <span class="pc-tag mono">Hub'eau API</span>
          <span class="pc-tag mono">SIG / Cartographie</span>
          <span class="pc-tag mono">JavaScript</span>
          <span class="pc-tag mono">Données publiques</span>
        </div>
      </article>

      <!-- Dual AI -->
      <article class="project-card" style="--i:3">
        <div class="pc-header">
          <div class="pc-meta">
            <span class="pc-badge mono pc-badge--open">Open Source</span>
          </div>
          <div class="pc-links">
            <a href="https://github.com/Manguet/dual-ai" target="_blank" rel="noopener" class="pc-link" aria-label="Voir sur GitHub">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
              GitHub
            </a>
          </div>
        </div>
        <h3 class="pc-title">Dual AI</h3>
        <p class="pc-desc" data-i18n="proj3_desc">Outil expérimental permettant à deux intelligences artificielles de débattre ensemble pour identifier la meilleure solution technique à un problème donné. Exploration des capacités de raisonnement comparatif des LLMs.</p>
        <div class="pc-tags">
          <span class="pc-tag mono">IA / LLM</span>
          <span class="pc-tag mono">Python</span>
          <span class="pc-tag mono">Open Source</span>
        </div>
      </article>

      <!-- Armagnac Baron de Lustrac -->
      <article class="project-card" style="--i:4">
        <div class="pc-header">
          <div class="pc-meta">
            <span class="pc-badge mono pc-badge--live">En ligne</span>
          </div>
          <div class="pc-links">
            <a href="https://www.armagnac-baron-de-lustrac.fr" target="_blank" rel="noopener" class="pc-link" aria-label="Voir le site">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              <span data-i18n="proj_visit">Visiter</span>
            </a>
          </div>
        </div>
        <h3 class="pc-title">Armagnac Baron de Lustrac</h3>
        <p class="pc-desc" data-i18n="proj4_desc">Site vitrine pour un producteur d'Armagnac. Projet à budget maîtrisé réalisé sous WordPress, avec un focus sur la mise en valeur du produit et une navigation simple pour un public de particuliers et de professionnels.</p>
        <div class="pc-tags">
          <span class="pc-tag mono">WordPress</span>
          <span class="pc-tag mono">Site vitrine</span>
          <span class="pc-tag mono">Petit budget</span>
        </div>
      </article>

      <!-- Boilerplate -->
      <article class="project-card" style="--i:5">
        <div class="pc-header">
          <div class="pc-meta">
            <span class="pc-badge mono pc-badge--soon" data-i18n="proj_soon">Bientôt disponible</span>
          </div>
          <div class="pc-links"></div>
        </div>
        <h3 class="pc-title">Boilerplate Symfony</h3>
        <p class="pc-desc" data-i18n="proj_boilerplate_desc">Socle applicatif Symfony 7.4 prêt à l'emploi. API Platform, JWT, authentification 2FA TOTP, architecture propre et Docker intégré. Base de départ pour démarrer rapidement un projet PHP moderne.</p>
        <div class="pc-tags">
          <span class="pc-tag mono">PHP 8.4 / Symfony 7.4</span>
          <span class="pc-tag mono">API Platform 4</span>
          <span class="pc-tag mono">JWT / 2FA TOTP</span>
          <span class="pc-tag mono">Docker</span>
        </div>
      </article>

      <!-- Marque blanche -->
      <article class="project-card project-card--blanche project-card--full" style="--i:6">
        <div class="pc-header">
          <div class="pc-meta">
            <span class="pc-badge mono pc-badge--blanche" data-i18n="proj_blanche_badge">Confidentiel</span>
          </div>
          <div class="pc-links"></div>
        </div>
        <h3 class="pc-title" data-i18n="proj5_title">Sous-traitance & Marque blanche</h3>
        <p class="pc-desc" data-i18n="proj5_desc">Plusieurs missions réalisées en marque blanche pour des agences digitales. Par nature confidentielle, ce type de collaboration ne peut être détaillée publiquement. N'hésitez pas à me contacter pour en discuter directement.</p>
        <div class="pc-tags">
          <span class="pc-tag mono">PHP / Symfony</span>
          <span class="pc-tag mono">Go</span>
          <span class="pc-tag mono">Python</span>
          <span class="pc-tag mono">Vue.js</span>
          <span class="pc-tag mono">Angular</span>
          <span class="pc-tag mono">WordPress</span>
          <span class="pc-tag mono">API REST</span>
        </div>
      </article>

    </div>
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* La première carte (Error Explorer) prend 2 colonnes */
  .project-card:first-child {
    grid-column: span 2;
  }

  .project-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
    animation: fadeUp 0.5s ease both;
    animation-delay: calc(var(--i) * 0.07s);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--purple), var(--purple-light));
    transform: scaleX(0);
    transition: transform 0.3s;
  }

  .project-card:hover { border-color: rgba(124,58,237,.4); transform: translateY(-3px); }
  .project-card:hover::before { transform: scaleX(1); }

  .project-card--featured {
    border-color: rgba(124,58,237,.35);
    background: linear-gradient(145deg, rgba(124,58,237,.07) 0%, var(--bg-2) 60%);
  }
  .project-card--featured::before { transform: scaleX(1); }

  .project-card--blanche {
    border-style: dashed;
    border-color: rgba(124,58,237,.2);
  }

  .pc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .pc-badge {
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase;
    padding: 3px 8px; border-radius: 100px;
  }

  .pc-badge--wip    { color: #fbbf24; background: rgba(251,191,36,.12); border: 1px solid rgba(251,191,36,.3); }
  .pc-badge--open   { color: #34d399; background: rgba(52,211,153,.12); border: 1px solid rgba(52,211,153,.3); }
  .pc-badge--live   { color: #60a5fa; background: rgba(96,165,250,.12); border: 1px solid rgba(96,165,250,.3); }
  .pc-badge--soon   { color: var(--purple-light); background: rgba(124,58,237,.12); border: 1px solid rgba(124,58,237,.3); }
  .pc-badge--blanche { color: var(--text-muted); background: var(--bg-3); border: 1px solid var(--border); }

  .project-card--full { grid-column: 1 / -1; }

  .pc-links { display: flex; gap: 8px; }

  .pc-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 600;
    color: var(--text-muted);
    background: var(--bg-3); border: 1px solid var(--border);
    padding: 5px 10px; border-radius: 4px;
    transition: color .2s, border-color .2s;
  }
  .pc-link:hover { color: var(--purple-light); border-color: rgba(124,58,237,.4); }

  .pc-title {
    font-size: 1.05rem; font-weight: 700;
    color: var(--white); text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .pc-desc {
    font-size: .85rem; color: var(--text-muted);
    line-height: 1.7; flex: 1;
  }

  .pc-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: auto; }

  .pc-tag {
    font-size: 11px; color: var(--text-muted);
    background: var(--bg-3); border: 1px solid var(--border);
    padding: 3px 8px; border-radius: 3px;
  }

  @media (max-width: 900px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
    .project-card:first-child { grid-column: span 2; }
  }

  @media (max-width: 600px) {
    .projects-grid { grid-template-columns: 1fr; }
    .project-card:first-child { grid-column: span 1; }
  }
</style>
