---
---
<section class="section" id="experience">
  <div class="container">
    <div class="section-label" data-i18n="section_xp_label">Parcours</div>
    <h2 class="section-title">
      <span data-i18n="section_xp_title">Expérience &amp; Formation</span>
    </h2>

    <div class="xp-layout">
      <!-- Timeline -->
      <div class="timeline">

        <!-- Error Explorer (fondateur) -->
        <div class="timeline-item current" style="--i:0">
          <div class="tl-dot"><span class="dot-pulse"></span></div>
          <div class="tl-content">
            <div class="tl-header">
              <span class="tl-period mono" data-i18n="job1_period">Jan. 2026 — Aujourd'hui</span>
              <span class="tl-badge mono" data-i18n="job1_badge">Actuel</span>
            </div>
            <h3 class="tl-role" data-i18n="job1_role">Extension de l'offre freelance</h3>
            <p class="tl-company">
              <strong data-i18n="job1_company">Indépendant</strong>
              <span class="tl-sep">·</span>
              <span class="tl-location" data-i18n="job1_loc">Bordeaux / Charente-Maritime · Remote</span>
            </p>
            <ul class="tl-items">
              <li class="tl-item" data-i18n="job1_i1">Audit sécurité web (OWASP, RGPD technique, audit flash)</li>
              <li class="tl-item" data-i18n="job1_i2">Développement full-stack PHP/Symfony, API REST, React/Preact</li>
              <li class="tl-item" data-i18n="job1_i3">Architecture technique et DevOps (CI/CD)</li>
              <li class="tl-item" data-i18n="job1_i4">Formation d'équipes : outils IA, Agile, bonnes pratiques dev</li>
              <li class="tl-item" data-i18n="job1_i5">Sous-traitance et marque blanche pour agences</li>
            </ul>
          </div>
        </div>

        <!-- Freelance -->
        <div class="timeline-item current" style="--i:1">
          <div class="tl-dot"><span class="dot-pulse"></span></div>
          <div class="tl-content">
            <div class="tl-header">
              <span class="tl-period mono" data-i18n="job2_period">Oct. 2023 — Aujourd'hui</span>
              <span class="tl-badge mono" data-i18n="job2_badge">Actuel</span>
            </div>
            <h3 class="tl-role" data-i18n="job2_role">Freelance</h3>
            <p class="tl-company">
              <strong data-i18n="job2_company">Indépendant</strong>
              <span class="tl-sep">·</span>
              <span class="tl-location" data-i18n="job2_loc">Remote</span>
            </p>
            <ul class="tl-items">
              <li class="tl-item" data-i18n="job2_i1">Développement full-stack Symfony, Go, Python, Angular</li>
              <li class="tl-item" data-i18n="job2_i2">Architecture technique et DevOps (CI/CD)</li>
              <li class="tl-item" data-i18n="job2_i3">Formation et accompagnement technique d'équipes</li>
              <li class="tl-item" data-i18n="job2_i4">Utilisation et formations IA</li>
            </ul>
          </div>
        </div>

        <!-- Negocian Lead -->
        <div class="timeline-item" style="--i:2">
          <div class="tl-dot"></div>
          <div class="tl-content">
            <div class="tl-header">
              <span class="tl-period mono" data-i18n="job3_period">Juin 2021 — Oct. 2023</span>
            </div>
            <h3 class="tl-role" data-i18n="job3_role">Leader Développeur Web PHP/Symfony</h3>
            <p class="tl-company">
              <strong data-i18n="job3_company">Negocian.Cloud</strong>
              <span class="tl-sep">·</span>
              <span class="tl-location" data-i18n="job3_loc">Mérignac · Hybride</span>
            </p>
            <ul class="tl-items">
              <li class="tl-item" data-i18n="job3_i1">Encadrement technique et formation des équipes</li>
              <li class="tl-item" data-i18n="job3_i2">Architecte de solutions</li>
              <li class="tl-item" data-i18n="job3_i3">Revue de code, validation de PR, amélioration des pratiques</li>
              <li class="tl-item" data-i18n="job3_i4">Pilotage des releases &amp; CI/CD</li>
              <li class="tl-item" data-i18n="job3_i5">Analyses fonctionnelles et spécifications techniques</li>
            </ul>
          </div>
        </div>

        <!-- Negocian Dev -->
        <div class="timeline-item" style="--i:3">
          <div class="tl-dot"></div>
          <div class="tl-content">
            <div class="tl-header">
              <span class="tl-period mono" data-i18n="job4_period">Juil. 2020 — Juin 2021</span>
            </div>
            <h3 class="tl-role" data-i18n="job4_role">Développeur Web PHP/Symfony</h3>
            <p class="tl-company">
              <strong data-i18n="job4_company">Negocian.Cloud</strong>
              <span class="tl-sep">·</span>
              <span class="tl-location" data-i18n="job4_loc">Mérignac</span>
            </p>
            <ul class="tl-items">
              <li class="tl-item" data-i18n="job4_i1">Développement back-end PHP/Symfony, jQuery</li>
              <li class="tl-item" data-i18n="job4_i2">Elastic Search, MySQL, MongoDB</li>
            </ul>
          </div>
        </div>

        <!-- Divers clients -->
        <div class="timeline-item" style="--i:4">
          <div class="tl-dot"></div>
          <div class="tl-content">
            <div class="tl-header">
              <span class="tl-period mono" data-i18n="job4b_period">Mai 2019 — Juil. 2020</span>
            </div>
            <h3 class="tl-role" data-i18n="job4b_role">Développeur Web PHP/Symfony</h3>
            <p class="tl-company">
              <strong data-i18n="job4b_company">Divers clients</strong>
              <span class="tl-sep">·</span>
              <span class="tl-location" data-i18n="job4b_loc">Freelance</span>
            </p>
            <ul class="tl-items">
              <li class="tl-item" data-i18n="job4b_i1">Développement back-end PHP/Symfony</li>
              <li class="tl-item" data-i18n="job4b_i2">Développement front-end React</li>
              <li class="tl-item" data-i18n="job4b_i3">MySQL, PostgreSQL</li>
            </ul>
          </div>
        </div>

        <!-- Sites vitrine 2015-2019 -->
        <div class="timeline-item" style="--i:5">
          <div class="tl-dot"></div>
          <div class="tl-content">
            <div class="tl-header">
              <span class="tl-period mono" data-i18n="job4c_period">2015 — 2019</span>
            </div>
            <h3 class="tl-role" data-i18n="job4c_role">Création de sites web</h3>
            <p class="tl-company">
              <strong data-i18n="job4c_company">Petites sociétés &amp; associations</strong>
              <span class="tl-sep">·</span>
              <span class="tl-location" data-i18n="job4c_loc">Freelance</span>
            </p>
            <ul class="tl-items">
              <li class="tl-item" data-i18n="job4c_i1">Sites vitrine WordPress</li>
              <li class="tl-item" data-i18n="job4c_i2">PHP / Symfony, JavaScript, React</li>
            </ul>
          </div>
        </div>

        <!-- Vétérinaire -->
        <div class="timeline-item" style="--i:6">
          <div class="tl-dot"></div>
          <div class="tl-content">
            <div class="tl-header">
              <span class="tl-period mono" data-i18n="job5_period">Sept. 2012 — Mai 2019</span>
            </div>
            <h3 class="tl-role" data-i18n="job5_role">Assistant Vétérinaire</h3>
            <p class="tl-company">
              <strong data-i18n="job5_company">Clinique Vétérinaire Alliance</strong>
              <span class="tl-sep">·</span>
              <span class="tl-location" data-i18n="job5_loc">Bordeaux</span>
            </p>
            <ul class="tl-items">
              <li class="tl-item" data-i18n="job5_i1">Chirurgie : anesthésies, surveillances opératoires</li>
              <li class="tl-item" data-i18n="job5_i2">Management d'équipe et formation de jeunes diplômés</li>
              <li class="tl-item" data-i18n="job5_i3">Contact clientèle professionnelle et particulière</li>
            </ul>
          </div>
        </div>

      </div>

      <!-- Sidebar Formation -->
      <div class="formation-block">
        <h3 class="formation-title mono" data-i18n="edu_title">Formation</h3>
        <div class="formation-list">
          <div class="formation-item" style="--i:0">
            <div class="formation-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                <path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            </div>
            <div>
              <p class="formation-name" data-i18n="edu1_name">Wild Code School</p>
              <p class="formation-sub mono" data-i18n="edu1_sub">Développeur Web PHP/Symfony · 2019-2020</p>
            </div>
          </div>
          <div class="formation-item" style="--i:1">
            <div class="formation-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                <path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            </div>
            <div>
              <p class="formation-name" data-i18n="edu2_name">OpenClassrooms</p>
              <p class="formation-sub mono" data-i18n="edu2_sub">Certification HTML/CSS · 2018</p>
            </div>
          </div>
          <div class="formation-item" style="--i:2">
            <div class="formation-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                <path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            </div>
            <div>
              <p class="formation-name" data-i18n="edu3_name">GIPSA · ASV Niveau V</p>
              <p class="formation-sub mono" data-i18n="edu3_sub">Auxiliaire Spécialisé Vétérinaire · 2010-2011</p>
            </div>
          </div>
        </div>

        <div class="formation-item" style="--i:3; margin-top:14px; padding-top:14px; border-top:1px solid var(--border)">
          <div class="formation-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            </svg>
          </div>
          <div>
            <p class="formation-name" data-i18n="jury_role">Membre du Jury — Titre ASV</p>
            <p class="formation-sub mono"><span data-i18n="jury_company">GIPSA</span> · <span data-i18n="jury_period">Mars 2015 · Mars 2017</span></p>
          </div>
        </div>

        <h3 class="formation-title mono" style="margin-top:32px" data-i18n="lang_title">Langues</h3>
        <div class="lang-list">
          <div class="lang-item">
            <span class="lang-name" data-i18n="lang1_name">Français</span>
            <span class="lang-level mono" data-i18n="lang1_lvl">Natif</span>
          </div>
          <div class="lang-item">
            <span class="lang-name" data-i18n="lang2_name">Anglais</span>
            <span class="lang-level mono" data-i18n="lang2_lvl">Professionnel</span>
          </div>
        </div>

        <h3 class="formation-title mono" style="margin-top:32px" data-i18n="hobbies_title">Veille &amp; Communauté</h3>
        <div class="hobby-list">
          <span class="hobby" data-i18n="hobby1">SymfonyCon</span>
          <span class="hobby" data-i18n="hobby2">Meetups (AFUP, French Tech)</span>
          <span class="hobby" data-i18n="hobby3">Piano &amp; stratégie</span>
          <span class="hobby" data-i18n="hobby4">Bénévolat animalier</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .xp-layout { display: grid; grid-template-columns: 1fr 320px; gap: 60px; align-items: start; }

  .timeline { position: relative; padding-left: 28px; }

  .timeline::before {
    content: '';
    position: absolute; left: 7px; top: 12px; bottom: 12px;
    width: 1px;
    background: linear-gradient(to bottom, var(--purple), var(--border));
  }

  .timeline-item {
    position: relative; margin-bottom: 40px;
    animation: fadeUp 0.5s ease both;
    animation-delay: calc(var(--i) * 0.08s);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .tl-dot {
    position: absolute; left: -28px; top: 4px;
    width: 15px; height: 15px; border-radius: 50%;
    background: var(--bg-2); border: 2px solid var(--border);
    display: flex; align-items: center; justify-content: center;
  }

  .timeline-item.current .tl-dot { border-color: var(--purple); background: var(--purple); }

  .dot-pulse {
    width: 5px; height: 5px; background: var(--white); border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: .5; transform: scale(.7); }
  }

  .tl-header { display: flex; align-items: center; gap: 10px; margin-bottom: 5px; }

  .tl-period { font-size: 12px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--text-muted); }

  .tl-badge {
    font-size: 10px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase;
    color: var(--purple-light);
    background: rgba(124,58,237,.15); border: 1px solid rgba(124,58,237,.3);
    padding: 2px 8px; border-radius: 100px;
  }

  .tl-role { font-size: 1.05rem; font-weight: 700; color: var(--white); text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 4px; }

  .tl-company { font-size: 13px; color: var(--text-muted); margin-bottom: 12px; display: flex; align-items: center; gap: 6px; }
  .tl-company strong { color: var(--purple-light); }
  .tl-sep { color: var(--border); }

  .tl-items { list-style: none; display: flex; flex-direction: column; gap: 5px; }

  .tl-item { font-size: 13px; color: var(--text-muted); padding-left: 16px; position: relative; line-height: 1.5; }
  .tl-item::before { content: '›'; position: absolute; left: 0; color: var(--purple-light); }

  /* Sidebar */
  .formation-block { background: var(--bg-2); border: 1px solid var(--border); border-radius: 8px; padding: 24px 20px; position: sticky; top: 100px; }

  .formation-title { font-size: 11px; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--purple-light); margin-bottom: 14px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }

  .formation-list { display: flex; flex-direction: column; gap: 14px; }

  .formation-item { display: flex; gap: 10px; align-items: flex-start; animation: fadeUp 0.4s ease both; animation-delay: calc(var(--i) * 0.1s); }

  .formation-icon { flex-shrink: 0; color: var(--purple-light); margin-top: 3px; }

  .formation-name { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 2px; }
  .formation-sub  { font-size: 11px; color: var(--text-muted); letter-spacing: .03em; }

  /* Langues */
  .lang-list { display: flex; flex-direction: column; gap: 8px; }
  .lang-item { display: flex; justify-content: space-between; align-items: center; }
  .lang-name { font-size: 13px; color: var(--text); }
  .lang-level { font-size: 11px; font-weight: 600; letter-spacing: .1em; color: var(--purple-light); background: rgba(124,58,237,.1); padding: 2px 7px; border-radius: 3px; }

  /* Hobbies */
  .hobby-list { display: flex; flex-wrap: wrap; gap: 7px; }
  .hobby { font-size: 11px; color: var(--text-muted); background: var(--bg-3); border: 1px solid var(--border); padding: 3px 9px; border-radius: 3px; }

  @media (max-width: 900px) { .xp-layout { grid-template-columns: 1fr; } .formation-block { position: static; } }
</style>
